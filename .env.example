# CHOK AI Backend local configuration example.
# Copy this file to .env for local overrides.
# Do not put real secrets in this example file.

CHOK_AI_APP_NAME="CHOK AI Backend"
CHOK_AI_APP_DESCRIPTION="FastAPI service shell for AI log analysis workflows."
CHOK_AI_APP_VERSION="0.1.0"

# JSON array format is used for list settings.
CHOK_AI_CORS_ORIGINS='["http://localhost:5173","http://127.0.0.1:5173","http://localhost:3000","http://127.0.0.1:3000"]'
CHOK_AI_CORS_METHODS='["GET","POST","PUT","PATCH","DELETE","OPTIONS"]'
CHOK_AI_CORS_HEADERS='["Authorization","Content-Type","Accept","X-Requested-With"]'
CHOK_AI_CORS_EXPOSED_HEADERS='["Authorization","X-Process-Time"]'
CHOK_AI_CORS_ALLOW_CREDENTIALS=true
CHOK_AI_CORS_MAX_AGE=3600

# OpenAI API Key
OPENAI_API_KEY=sk-...